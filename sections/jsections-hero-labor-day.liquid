      "default": "#FFC0CB"
    },
    {
      "type": "color",
      "id": "gradient_color_2",
      "label": "Gradient color 2",
      "default": "#F5E6D3"
    },
    {
      "type": "select",
      "id": "gradient_direction",
      "label": "Gradient direction",
