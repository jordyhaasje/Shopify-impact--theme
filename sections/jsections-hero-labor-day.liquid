      "id": "subheading",
      "label": "Subheading",
      "default": "65% off sitewide."
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body text",
      "default": "Discover how our solution can transform your experience with innovative features designed for your success."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "shop now"
    },
    {
