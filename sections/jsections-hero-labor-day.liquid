        },
        {
          "value": "to bottom",
          "label": "Top to bottom"
        },
        {
          "value": "to bottom right",
          "label": "Diagonal (top-left to bottom-right)"
        },
        {
          "value": "135deg",
          "label": "Diagonal 135°"
        },
        {
          "value": "to top",
          "label": "Bottom to top"
        },
        {
          "value": "to left",
          "label": "Right to left"
        }
