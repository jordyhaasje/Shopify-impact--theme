      "default": "#333030"
    },
    {
      "type": "color",
      "id": "circle_bg",
      "label": "Circle background",
      "default": "#333030"
    },
    {
      "type": "color",
      "id": "circle_icon_color",
      "label": "Circle icon color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "badge_bg",
      "label": "Badge background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge text color",
      "default": "#333030"
    },
    {
      "type": "color",
      "id": "badge_border_color",
      "label": "Badge border color",
      "default": "#333030"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Step title color",
      "default": "#333030"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Step description color",
      "default": "#333030"
    },
    {
      "type": "header",
