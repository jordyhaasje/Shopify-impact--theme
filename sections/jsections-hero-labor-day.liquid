{%- comment -%}
  JSections - Hero Labor Day Sale
  Version: 1.0.0
  Installed by: Hazify Sections

  ⚠️ Do not modify - updates will overwrite changes.
  To customize, duplicate this section in your theme.
{%- endcomment -%}

{{ 'jsections-hero-labor-day.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign bg_type = section.settings.bg_type
  assign bg_opacity = section.settings.bg_opacity | divided_by: 100.0
  
  if bg_type == 'gradient'
    assign bg_style = 'linear-gradient(' | append: section.settings.gradient_direction | append: ', ' | append: section.settings.gradient_color_1 | append: ', ' | append: section.settings.gradient_color_2 | append: ')'
  else
    assign bg_style = section.settings.solid_bg_color
  endif
  
  assign image_opacity = section.settings.image_opacity | divided_by: 100.0
  assign image_blend = 'normal'
  if section.settings.image_transparent_blend
    assign image_blend = 'multiply'
  endif
-%}

<div
  class="hero-labor-day"
  style="
    --bg-opacity: {{ bg_opacity }};
    --padding-top: {{ section.settings.padding_top }}px;
    --padding-bottom: {{ section.settings.padding_bottom }}px;
    --min-height: {{ section.settings.min_height }}px;
    --text-align: {{ section.settings.text_alignment }};
    --image-opacity: {{ image_opacity }};
    --image-blend: {{ image_blend }};
  "
  {{ section.shopify_attributes }}
>
  <div class="hero-labor-day__background" style="{% if bg_type == 'gradient' %}background: {{ bg_style }};{% else %}background-color: {{ bg_style }};{% endif %} opacity: var(--bg-opacity);"></div>
  
  <div class="hero-labor-day__container">
    <div class="hero-labor-day__content">
      {%- if section.settings.heading != blank -%}
        <h1 class="hero-labor-day__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}
      
      {%- if section.settings.subheading != blank -%}
        <p class="hero-labor-day__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
      
      {%- if section.settings.body_text != blank -%}
        <p class="hero-labor-day__body">{{ section.settings.body_text }}</p>
      {%- endif -%}
      
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_url | default: '#' }}" class="hero-labor-day__button">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
      
      {%- if section.settings.trust_badge_text != blank -%}
        <div class="hero-labor-day__trust-badge">
          <svg class="hero-labor-day__check-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
            <circle cx="8" cy="8" r="8" fill="currentColor" fill-opacity="0.2"/>
            <path d="M11.5 5.5L6.5 10.5L4.5 8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>{{ section.settings.trust_badge_text }}</span>
        </div>
      {%- endif -%}
    </div>
    
    {%- if section.settings.hero_image != blank -%}
      <div class="hero-labor-day__image-wrapper">
        <img
          srcset="
            {%- if section.settings.hero_image.width >= 375 -%}{{ section.settings.hero_image | image_url: width: 375 }} 375w,{%- endif -%}
            {%- if section.settings.hero_image.width >= 550 -%}{{ section.settings.hero_image | image_url: width: 550 }} 550w,{%- endif -%}
            {%- if section.settings.hero_image.width >= 750 -%}{{ section.settings.hero_image | image_url: width: 750 }} 750w,{%- endif -%}
            {%- if section.settings.hero_image.width >= 1000 -%}{{ section.settings.hero_image | image_url: width: 1000 }} 1000w,{%- endif -%}
            {%- if section.settings.hero_image.width >= 1500 -%}{{ section.settings.hero_image | image_url: width: 1500 }} 1500w,{%- endif -%}
            {{ section.settings.hero_image | image_url }} {{ section.settings.hero_image.width }}w
          "
          src="{{ section.settings.hero_image | image_url: width: 750 }}"
          loading="lazy"
          alt="{{ section.settings.hero_image.alt | escape }}"
          width="{{ section.settings.hero_image.width }}"
          height="{{ section.settings.hero_image.height }}"
          class="hero-labor-day__image"
        >
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "HS - Hero #2",
  "tag": "section",
  "class": "jsections-hero-labor-day",
  "settings": [
    {
