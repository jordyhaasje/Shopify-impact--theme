{%- comment -%}
  JSections - Trustpilot Reviews
  Version: 1.0.0
  Installed by: Hazify Sections

  Do not modify - updates will overwrite changes.
  To customize, duplicate this section in your theme.
{%- endcomment -%}

{{ 'jsections-trustpilot-reviews.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign has_review_1 = false
  assign has_review_2 = false
  assign has_review_3 = false

  if section.settings.review_1_title != blank
    assign has_review_1 = true
  endif
  if section.settings.review_2_title != blank
    assign has_review_2 = true
  endif
  if section.settings.review_3_title != blank
    assign has_review_3 = true
  endif

  assign review_count = 0
  if has_review_1
    assign review_count = review_count | plus: 1
  endif
  if has_review_2
    assign review_count = review_count | plus: 1
  endif
  if has_review_3
    assign review_count = review_count | plus: 1
  endif
-%}

<section
  class="tp-section"
  style="
    --tp-section-bg: {{ section.settings.section_background }};
    --tp-section-padding-top: {{ section.settings.padding_top }}px;
    --tp-section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --tp-container-width: {{ section.settings.container_width }}px;
  "
>
  <div
    class="tp-widget tp-widget--section"
    data-section-id="{{ section.id }}"
    {{ section.shopify_attributes }}
  >
    <div class="tp-widget-container">

      {%- if section.settings.show_heading and section.settings.heading_text != blank -%}
        <div class="tp-heading" role="presentation">
          <span class="tp-heading-title">{{ section.settings.heading_text }}</span>
          <span class="tp-heading-logo" aria-label="Trustpilot">
            <svg class="tp-heading-icon" viewBox="0 0 16 16" aria-hidden="true">
              <polygon fill="#00B67A" points="8,0 10.2,6 16,6 11.3,9.5 13,16 8,12.2 3,16 4.7,9.5 0,6 5.8,6"/>
            </svg>
            <span class="tp-heading-brand">Trustpilot</span>
          </span>
        </div>
      {%- endif -%}

      {%- if review_count > 0 -%}
        <div class="tp-carousel-wrapper">

          <button
            type="button"
            class="tp-nav-button tp-nav-button--prev"
            aria-label="Previous review"
            data-direction="prev"
            disabled
          >
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
          </button>

          <div class="tp-carousel" role="region" aria-label="Trustpilot reviews carousel">
            <div class="tp-carousel-track" data-reviews-track>

              {%- if has_review_1 -%}
                <div class="tp-review-card">
                  <a
                    href="{{ section.settings.profile_url | default: '#' }}"
                    class="tp-review-link"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Review by {{ section.settings.review_1_author }}: {{ section.settings.review_1_title }}"
                  >
                    <div class="tp-stars-wrapper">
                      {% render 'jsections-custos-trustpilot-stars' %}
                    </div>
                    {%- if section.settings.review_1_verified -%}
                      <div class="tp-verified-badge">
                        <span class="tp-verified-icon">
                          <svg viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <circle class="tp-verified-circle" cx="8" cy="8" r="8"/>
                            <path class="tp-verified-check" d="M11.2 5.6L6.8 10.4L4.8 8.4" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                          </svg>
                        </span>
                        <span>{{ section.settings.verified_text | default: 'Verified' }}</span>
                      </div>
                    {%- endif -%}
                    <h3 class="tp-review-title">{{ section.settings.review_1_title }}</h3>
                    {%- if section.settings.review_1_text != blank -%}
                      <p class="tp-review-text">{{ section.settings.review_1_text }}</p>
                    {%- endif -%}
                    <div class="tp-review-author">
                      {%- if section.settings.review_1_author != blank -%}
                        <span class="tp-review-author-name">{{ section.settings.review_1_author }}</span>
                      {%- endif -%}
                      {%- if section.settings.review_1_date != blank -%}
                        <span class="tp-review-date">{{ section.settings.review_1_date }}</span>
                      {%- endif -%}
                    </div>
                  </a>
                </div>
              {%- endif -%}

              {%- if has_review_2 -%}
                <div class="tp-review-card">
                  <a
                    href="{{ section.settings.profile_url | default: '#' }}"
                    class="tp-review-link"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Review by {{ section.settings.review_2_author }}: {{ section.settings.review_2_title }}"
                  >
                    <div class="tp-stars-wrapper">
                      {% render 'jsections-custos-trustpilot-stars' %}
                    </div>
                    {%- if section.settings.review_2_verified -%}
                      <div class="tp-verified-badge">
                        <span class="tp-verified-icon">
                          <svg viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <circle class="tp-verified-circle" cx="8" cy="8" r="8"/>
                            <path class="tp-verified-check" d="M11.2 5.6L6.8 10.4L4.8 8.4" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                          </svg>
                        </span>
                        <span>{{ section.settings.verified_text | default: 'Verified' }}</span>
                      </div>
                    {%- endif -%}
                    <h3 class="tp-review-title">{{ section.settings.review_2_title }}</h3>
                    {%- if section.settings.review_2_text != blank -%}
                      <p class="tp-review-text">{{ section.settings.review_2_text }}</p>
                    {%- endif -%}
                    <div class="tp-review-author">
                      {%- if section.settings.review_2_author != blank -%}
                        <span class="tp-review-author-name">{{ section.settings.review_2_author }}</span>
                      {%- endif -%}
                      {%- if section.settings.review_2_date != blank -%}
                        <span class="tp-review-date">{{ section.settings.review_2_date }}</span>
                      {%- endif -%}
                    </div>
                  </a>
                </div>
              {%- endif -%}

              {%- if has_review_3 -%}
                <div class="tp-review-card">
                  <a
                    href="{{ section.settings.profile_url | default: '#' }}"
                    class="tp-review-link"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Review by {{ section.settings.review_3_author }}: {{ section.settings.review_3_title }}"
                  >
                    <div class="tp-stars-wrapper">
                      {% render 'jsections-custos-trustpilot-stars' %}
                    </div>
                    {%- if section.settings.review_3_verified -%}
                      <div class="tp-verified-badge">
                        <span class="tp-verified-icon">
                          <svg viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <circle class="tp-verified-circle" cx="8" cy="8" r="8"/>
                            <path class="tp-verified-check" d="M11.2 5.6L6.8 10.4L4.8 8.4" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                          </svg>
                        </span>
                        <span>{{ section.settings.verified_text | default: 'Verified' }}</span>
                      </div>
                    {%- endif -%}
                    <h3 class="tp-review-title">{{ section.settings.review_3_title }}</h3>
                    {%- if section.settings.review_3_text != blank -%}
                      <p class="tp-review-text">{{ section.settings.review_3_text }}</p>
                    {%- endif -%}
                    <div class="tp-review-author">
                      {%- if section.settings.review_3_author != blank -%}
                        <span class="tp-review-author-name">{{ section.settings.review_3_author }}</span>
                      {%- endif -%}
                      {%- if section.settings.review_3_date != blank -%}
                        <span class="tp-review-date">{{ section.settings.review_3_date }}</span>
                      {%- endif -%}
                    </div>
                  </a>
                </div>
              {%- endif -%}

            </div>
          </div>

          <button
            type="button"
            class="tp-nav-button tp-nav-button--next"
            aria-label="Next review"
            data-direction="next"
            {%- if review_count <= 1 %} disabled{%- endif -%}
          >
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </button>

        </div>
      {%- endif -%}

      {%- if section.settings.show_footer -%}
        <div class="tp-footer">
          <a
            href="{{ section.settings.profile_url | default: '#' }}"
            class="tp-footer-link"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="View our Trustpilot profile - Score {{ section.settings.score }} out of 5"
          >
            <p class="tp-footer-text">
              Score <span class="tp-footer-score">{{ section.settings.score }}</span> out of 5 based on <span class="tp-footer-reviews">{{ section.settings.review_count }}</span>. {{ section.settings.footer_subtitle }}.
            </p>

            <div class="tp-logo-wrapper">
              {% render 'jsections-custos-trustpilot-logo' %}
            </div>
          </a>
        </div>
      {%- endif -%}

    </div>
  </div>
</section>

<script>
(function() {
  'use strict';

  function initCarousels() {
    const widgets = document.querySelectorAll('.tp-widget');
    widgets.forEach(function(widget) {
      initCarousel(widget);
    });
  }

  function initCarousel(widget) {
    const track = widget.querySelector('[data-reviews-track]');
    const prevBtn = widget.querySelector('.tp-nav-button--prev');
    const nextBtn = widget.querySelector('.tp-nav-button--next');

    if (!track || !prevBtn || !nextBtn) return;

    const cards = track.querySelectorAll('.tp-review-card');
    if (cards.length === 0) return;

    let currentIndex = 0;

    function getVisibleCards() {
      return 1;
    }

    function getMaxIndex() {
      const visible = getVisibleCards();
      return Math.max(0, cards.length - visible);
    }

    function updateCarousel() {
      const visible = getVisibleCards();
      const maxIndex = getMaxIndex();

      if (currentIndex > maxIndex) {
        currentIndex = maxIndex;
      }

      const cardWidth = 100 / visible;
      const offset = currentIndex * cardWidth;
      track.style.transform = 'translateX(-' + offset + '%)';

      prevBtn.disabled = currentIndex === 0;
      nextBtn.disabled = currentIndex >= maxIndex;
    }

    function goToPrev() {
      if (currentIndex > 0) {
        currentIndex--;
        updateCarousel();
      }
    }

    function goToNext() {
      if (currentIndex < getMaxIndex()) {
        currentIndex++;
        updateCarousel();
      }
    }

    prevBtn.addEventListener('click', goToPrev);
    nextBtn.addEventListener('click', goToNext);

    let resizeTimeout;
    window.addEventListener('resize', function() {
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(updateCarousel, 100);
    });

    widget.addEventListener('keydown', function(e) {
      if (e.key === 'ArrowLeft') {
        goToPrev();
      } else if (e.key === 'ArrowRight') {
        goToNext();
      }
    });

    let touchStartX = 0;
    let touchEndX = 0;

    track.addEventListener('touchstart', function(e) {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });

    track.addEventListener('touchend', function(e) {
      touchEndX = e.changedTouches[0].screenX;
      handleSwipe();
    }, { passive: true });

    function handleSwipe() {
      const diff = touchStartX - touchEndX;
      const threshold = 50;

      if (diff > threshold) {
        goToNext();
      } else if (diff < -threshold) {
        goToPrev();
      }
    }

    updateCarousel();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCarousels);
  } else {
    initCarousels();
  }

  document.addEventListener('shopify:section:load', function(event) {
    const section = event.target;
    const widgets = section.querySelectorAll('.tp-widget');
    widgets.forEach(initCarousel);
  });
})();
</script>

