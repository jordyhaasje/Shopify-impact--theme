          "default": "<p>Skin drinks it in instantly. Dry spots feel soothed, and you’ll notice a softer, more nourished surface right away.</p>"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "leaf",
          "options": [
            { "value": "leaf", "label": "Leaf" },
            { "value": "droplet", "label": "Droplet" },
            { "value": "shield", "label": "Shield" },
            { "value": "spark", "label": "Spark" }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Roadmap steps",
      "category": "Product",
      "blocks": [
        { "type": "step" },
        { "type": "step", "settings": { "badge": "Week 2", "title": "Deep Hydration", "description": "<p>Fine lines start to blur as your skin barrier strengthens. The whipped balm’s nutrients lock in long-lasting moisture.</p>", "icon": "droplet" } },
        { "type": "step", "settings": { "badge": "Week 3", "title": "Repair Mode", "description": "<p>Redness and irritation calm down, while your skin feels balanced, smooth, and more resilient.</p>", "icon": "shield" } },
        { "type": "step", "settings": { "badge": "Week 4", "title": "Complete skin transformation", "description": "<p>Your complexion glows with health. Stronger, shielded, and radiant—your skin is thriving the Sunny Side way.</p>", "icon": "spark" } }
      ]
    }
  ]
}
{% endschema %}
