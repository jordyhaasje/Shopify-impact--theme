      "default": false
    },
    {
      "type": "range",
      "id": "image_opacity",
      "label": "Image opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 85
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
