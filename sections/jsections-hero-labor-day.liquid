      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "text",
      "id": "trust_badge_text",
      "label": "Trust badge text",
      "default": "30-Day Money-Back Guarantee"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Section padding top",
      "min": 0,
