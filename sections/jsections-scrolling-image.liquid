{%- comment -%}
  JSections - Scrolling Images
  Version: 1.0.0
  Installed by: Hazify Sections

  ⚠️ Do not modify - updates will overwrite changes.
  To customize, duplicate this section in your theme.
{%- endcomment -%}

{{ 'jsections-scrolling-image.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign heading = section.settings.heading
  assign show_heading = section.settings.show_heading

  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign section_bg = section.settings.section_background

  assign slide_width = section.settings.slide_width
  assign slide_height = section.settings.slide_height
  assign slide_radius = section.settings.slide_radius
  assign slide_gap = section.settings.slide_gap

  assign slide_width_mobile = section.settings.slide_width_mobile
  assign slide_height_mobile = section.settings.slide_height_mobile
  assign slide_gap_mobile = section.settings.slide_gap_mobile

  assign animation_seconds = section.settings.animation_seconds
  assign direction = section.settings.direction
  assign pause_on_hover = section.settings.pause_on_hover
  assign duplicate_tracks = section.settings.duplicate_tracks

  assign content_text = section.settings.content_text
  assign show_content = section.settings.show_content
  assign content_max_width = section.settings.content_max_width
  assign content_padding = section.settings.content_padding
  assign content_radius = section.settings.content_radius
  assign content_border_width = section.settings.content_border_width
  assign content_border_color = section.settings.content_border_color
  assign content_text_color = section.settings.content_text_color
  assign content_bg = section.settings.content_bg
  assign content_offset = section.settings.content_offset
  assign content_align = section.settings.content_align
  assign enable_glass = section.settings.enable_glass
  assign glass_blur = section.settings.glass_blur
  assign glass_opacity = section.settings.glass_opacity
  assign glass_saturation = section.settings.glass_saturation
  assign glass_specular = section.settings.glass_specular
  assign content_hover_scale = section.settings.content_hover_scale

  assign block_count = section.blocks.size
  assign track_width = slide_width | plus: slide_gap | times: block_count
  assign track_width_mobile = slide_width_mobile | plus: slide_gap_mobile | times: block_count

  if block_count == 0
    assign block_count = 6
    assign track_width = slide_width | plus: slide_gap | times: block_count
    assign track_width_mobile = slide_width_mobile | plus: slide_gap_mobile | times: block_count
  endif
-%}

<div class="scrolling-image" style="
  --si-bg: {{ section_bg }};
  --si-padding-top: {{ padding_top }}px;
  --si-padding-bottom: {{ padding_bottom }}px;
  --si-heading-size: {{ section.settings.heading_size }}px;
  --si-heading-color: {{ section.settings.heading_color }};
  --si-slide-width: {{ slide_width }}px;
  --si-slide-height: {{ slide_height }}px;
  --si-slide-radius: {{ slide_radius }}px;
  --si-gap: {{ slide_gap }}px;
  --si-slide-width-mobile: {{ slide_width_mobile }}px;
  --si-slide-height-mobile: {{ slide_height_mobile }}px;
  --si-gap-mobile: {{ slide_gap_mobile }}px;
  --si-track-width: {{ track_width }}px;
  --si-track-width-mobile: {{ track_width_mobile }}px;
  --si-speed: {{ animation_seconds }}s;
  --si-content-max: {{ content_max_width }}px;
  --si-content-padding: {{ content_padding }}px;
  --si-content-radius: {{ content_radius }}px;
  --si-content-border: {{ content_border_width }}px solid {{ content_border_color }};
  --si-content-text: {{ content_text_color }};
  --si-content-bg: {{ content_bg }};
  --si-content-offset: {{ content_offset }}px;
  --si-glass-blur: {{ glass_blur }}px;
  --si-glass-opacity: {{ glass_opacity }};
  --si-glass-saturation: {{ glass_saturation }};
  --si-glass-specular: {{ glass_specular }};
">
  <div class="scrolling-image__inner">
    {%- if show_heading and heading != blank -%}
      <div class="scrolling-image__heading">
        <h2>{{ heading }}</h2>
      </div>
    {%- endif -%}

    <div class="scrolling-image__slider marquee marquee--{{ direction }}{% if pause_on_hover %} marquee--pause{% endif %}">
      {%- for i in (1..duplicate_tracks) -%}
        <div class="marquee__track">
          {%- if section.blocks.size > 0 -%}
            {%- for block in section.blocks -%}
              {%- assign image = block.settings.image -%}
              {%- assign link = block.settings.link -%}
              {%- assign block_attrs = '' -%}
              {%- if i == 1 -%}
                {%- assign block_attrs = block.shopify_attributes -%}
              {%- endif -%}
              <div class="scrolling-image__slide" {{ block_attrs }}>
                {%- if image != blank -%}
                  {%- if link != blank -%}
                    <a href="{{ link }}" class="scrolling-image__link">
                      {{ image | image_url: width: 2000 | image_tag: loading: 'lazy', sizes: '200px' }}
                    </a>
                  {%- else -%}
                    {{ image | image_url: width: 2000 | image_tag: loading: 'lazy', sizes: '200px' }}
                  {%- endif -%}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag }}
                {%- endif -%}
              </div>
            {%- endfor -%}
          {%- else -%}
            {%- for j in (1..6) -%}
              <div class="scrolling-image__slide">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    {%- if show_content and content_text != blank -%}
      <div class="scrolling-image__content scrolling-image__content--{{ content_align }}{% if enable_glass %} is-glass{% endif %}{% if content_hover_scale %} is-hover-scale{% endif %}">
        {%- if enable_glass -%}
          <span class="scrolling-image__glass-filter"></span>
          <span class="scrolling-image__glass-overlay"></span>
          <span class="scrolling-image__glass-specular"></span>
        {%- endif -%}
        <div class="scrolling-image__content-inner">
          {{ content_text }}
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

