{%- comment -%}
  JSections - Reviews Advanced
  Version: 1.0.0
  Installed by: Hazify Sections

  Do not modify - updates will overwrite changes.
  To customize, duplicate this section in your theme.
{%- endcomment -%}

{{ 'jsections-reviews-advanced.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign total_reviews = section.settings.total_reviews
  assign count_5 = section.settings.count_5
  assign count_4 = section.settings.count_4
  assign count_3 = section.settings.count_3
  assign count_2 = section.settings.count_2
  assign count_1 = section.settings.count_1

  assign total_count = count_5 | plus: count_4 | plus: count_3 | plus: count_2 | plus: count_1
  if total_count == 0
    assign total_count = 1
  endif

  assign percent_5 = count_5 | times: 100 | divided_by: total_count
  assign percent_4 = count_4 | times: 100 | divided_by: total_count
  assign percent_3 = count_3 | times: 100 | divided_by: total_count
  assign percent_2 = count_2 | times: 100 | divided_by: total_count
  assign percent_1 = count_1 | times: 100 | divided_by: total_count

  assign metric_index = 0
  assign first_metric_percentage = 0
  assign first_metric_left = section.settings.metric_left_label
  assign first_metric_center = section.settings.metric_center_label
  assign first_metric_right = section.settings.metric_right_label

  for block in section.blocks
    if block.type == 'metric'
      assign metric_index = metric_index | plus: 1
      if metric_index == 1
        assign first_metric_percentage = block.settings.value | times: 100 | divided_by: 3
        assign first_metric_left = block.settings.left_label
        assign first_metric_center = block.settings.center_label
        assign first_metric_right = block.settings.right_label
      endif
    endif
  endfor
-%}

<section
  id="reviews"
  class="reviews-advanced"
  style="
    --reviews-bg: {{ section.settings.background }};
    --reviews-text: {{ section.settings.text_color }};
    --reviews-muted: {{ section.settings.muted_color }};
    --reviews-title-size: {{ section.settings.title_size }}px;
    --reviews-padding-y: {{ section.settings.padding_top }}px;
    --reviews-padding-x: {{ section.settings.padding_side }}px;
    --reviews-max-width: {{ section.settings.max_width }}px;
    --accent-color: {{ section.settings.accent_color }};
    --accent-contrast: {{ section.settings.accent_contrast }};
    --summary-bg: {{ section.settings.summary_bg }};
    --summary-border: {{ section.settings.summary_border }};
    --summary-radius: {{ section.settings.summary_radius }}px;
    --avg-bg: {{ section.settings.avg_bg }};
    --avg-border: {{ section.settings.avg_border }};
    --avg-radius: {{ section.settings.avg_radius }}px;
    --bar-bg: {{ section.settings.bar_bg }};
    --bar-fill: {{ section.settings.bar_fill }};
    --tab-border: {{ section.settings.tab_border }};
    --tab-active-bg: {{ section.settings.tab_active_bg }};
    --tab-active-text: {{ section.settings.tab_active_text }};
    --filter-bg: {{ section.settings.filter_bg }};
    --filter-border: {{ section.settings.filter_border }};
    --card-bg: {{ section.settings.card_bg }};
    --card-border: {{ section.settings.card_border }};
    --card-radius: {{ section.settings.card_radius }}px;
    --tag-border: {{ section.settings.tag_border }};
    --button-bg: {{ section.settings.button_bg }};
    --button-text: {{ section.settings.button_text }};
    --button-border: {{ section.settings.button_border }};
  "
>
  <div class="reviews-advanced__inner">
    <h2 class="reviews-advanced__title">{{ section.settings.heading }}</h2>

    <div class="reviews-advanced__grid">
      <section class="reviews-summary">
        <div class="reviews-summary__rating" aria-label="{{ section.settings.rating_value }} out of 5 stars">
          <span class="reviews-summary__score">{{ section.settings.rating_value }}</span>
          <div class="reviews-summary__stars" aria-label="Rating: {{ section.settings.rating_value }} out of 5 stars" role="img">
            {%- for i in (1..5) -%}
              {%- assign star_value = section.settings.rating_value | minus: i | plus: 1 -%}
              {%- if star_value < 0 -%}
                {%- assign star_value = 0 -%}
              {%- elsif star_value > 1 -%}
                {%- assign star_value = 1 -%}
              {%- endif -%}
              {%- assign star_percent = star_value | times: 100 -%}
              <span class="reviews-star">
                <svg width="24" height="24" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <defs>
                    <clipPath id="reviews-star-{{ section.id }}-{{ forloop.index }}">
                      <path d="M22.3498 27.54L14.0005 21.0646L5.60596 27.5165L8.8893 17.1675L0.460938 10.7745L10.8412 10.8569L14.0005 0.460938L17.1484 10.8569L27.5513 10.8216L19.1116 17.1675L22.3611 27.5518L22.3498 27.54Z" fill="{{ section.settings.star_fill }}"></path>
                    </clipPath>
                  </defs>
                  <rect x="0" y="0" width="{{ star_percent }}%" height="100%" fill="{{ section.settings.star_fill }}" clip-path="url(#reviews-star-{{ section.id }}-{{ forloop.index }})"></rect>
                  <rect x="{{ star_percent }}%" y="0" width="100%" height="100%" fill="{{ section.settings.star_empty }}" clip-path="url(#reviews-star-{{ section.id }}-{{ forloop.index }})"></rect>
                </svg>
              </span>
            {%- endfor -%}
          </div>
        </div>

        <p class="reviews-summary__total">{{ section.settings.total_text | replace: '[count]', total_reviews }}</p>
        <p class="reviews-summary__recommend">
          <span class="reviews-icon reviews-icon--check" aria-hidden="true">
            <svg viewBox="0 0 24 24" role="presentation">
              <path d="M9.2 16.2L5.6 12.6L4.2 14L9.2 19L20 8.2L18.6 6.8L9.2 16.2Z" fill="currentColor"></path>
            </svg>
          </span>
          {{ section.settings.recommend_percent }}% of people asked would recommend this
        </p>

        <h4 class="reviews-summary__section-title">{{ section.settings.snapshot_title }}</h4>
        <div class="reviews-breakdown">
          <div class="reviews-breakdown__label">5 ({{ count_5 }})</div>
          <div class="reviews-breakdown__bar" style="--percentage: {{ percent_5 }}%"></div>
          <div class="reviews-breakdown__label">4 ({{ count_4 }})</div>
          <div class="reviews-breakdown__bar" style="--percentage: {{ percent_4 }}%"></div>
          <div class="reviews-breakdown__label">3 ({{ count_3 }})</div>
          <div class="reviews-breakdown__bar" style="--percentage: {{ percent_3 }}%"></div>
          <div class="reviews-breakdown__label">2 ({{ count_2 }})</div>
          <div class="reviews-breakdown__bar" style="--percentage: {{ percent_2 }}%"></div>
          <div class="reviews-breakdown__label">1 ({{ count_1 }})</div>
          <div class="reviews-breakdown__bar" style="--percentage: {{ percent_1 }}%"></div>
        </div>
      </section>

      <section class="reviews-average">
        <h2 class="reviews-average__title">{{ section.settings.average_title }}</h2>
        <div class="reviews-average__tabs" data-reviews-metrics>
          {%- assign metric_tab_index = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'metric' -%}
              {%- assign metric_tab_index = metric_tab_index | plus: 1 -%}
              {%- assign metric_percent = block.settings.value | times: 100 | divided_by: 3 -%}
              <button
                class="reviews-average__tab{% if metric_tab_index == 1 %} is-active{% endif %}"
                data-metric-index="{{ metric_tab_index }}"
                data-percentage="{{ metric_percent }}"
                data-left="{{ block.settings.left_label }}"
                data-center="{{ block.settings.center_label }}"
                data-right="{{ block.settings.right_label }}"
                type="button"
              >
                {{ block.settings.label }}
              </button>
            {%- endif -%}
          {%- endfor -%}
        </div>
        <div class="reviews-average__bar" style="--percentage: {{ first_metric_percentage }}%"></div>
        <div class="reviews-average__labels">
          <span data-metric-left>{{ first_metric_left }}</span>
          <span data-metric-center>{{ first_metric_center }}</span>
          <span data-metric-right>{{ first_metric_right }}</span>
        </div>
      </section>
    </div>

    {%- if section.settings.show_filters -%}
      <div class="reviews-filters">
        {%- if section.settings.show_search -%}
          <div class="reviews-search">
            <input type="text" placeholder="{{ section.settings.search_placeholder }}" aria-label="{{ section.settings.search_placeholder }}">
          </div>
        {%- endif -%}
        <div class="reviews-filter-row">
          {%- if section.settings.show_sort -%}
            <div class="reviews-filter">
              <label>{{ section.settings.sort_label }}</label>
              <select>
                <option value="recent">{{ section.settings.sort_option_recent }}</option>
                <option value="oldest">{{ section.settings.sort_option_oldest }}</option>
                <option value="highest">{{ section.settings.sort_option_highest }}</option>
                <option value="lowest">{{ section.settings.sort_option_lowest }}</option>
              </select>
            </div>
          {%- endif -%}
          {%- if section.settings.show_rating_filter -%}
            <div class="reviews-filter">
              <label>{{ section.settings.rating_filter_label }}</label>
              <select>
                <option value="">{{ section.settings.rating_filter_placeholder }}</option>
                <option value="5">5 Stars</option>
                <option value="4">4 Stars</option>
                <option value="3">3 Stars</option>
                <option value="2">2 Stars</option>
                <option value="1">1 Star</option>
              </select>
            </div>
          {%- endif -%}
          {%- if section.settings.show_activity_filter -%}
            <div class="reviews-filter">
              <label>{{ section.settings.activity_filter_label }}</label>
              <select>
                <option value="">{{ section.settings.activity_filter_placeholder }}</option>
                <option value="Weight / strength training">Weight / strength training</option>
                <option value="Indoor cardio">Indoor cardio</option>
                <option value="Running errands">Running errands</option>
              </select>
            </div>
          {%- endif -%}
          {%- if section.settings.show_age_filter -%}
            <div class="reviews-filter">
              <label>{{ section.settings.age_filter_label }}</label>
              <select>
                <option value="">{{ section.settings.age_filter_placeholder }}</option>
                <option value="18 to 24">18 to 24</option>
                <option value="25 to 34">25 to 34</option>
                <option value="35 to 44">35 to 44</option>
                <option value="45 to 54">45 to 54</option>
                <option value="55 to 64">55 to 64</option>
              </select>
            </div>
          {%- endif -%}
          {%- if section.settings.show_frequency_filter -%}
            <div class="reviews-filter">
              <label>{{ section.settings.frequency_filter_label }}</label>
              <select>
                <option value="">{{ section.settings.frequency_filter_placeholder }}</option>
                <option value="3 - 6 times a week">3 - 6 times a week</option>
                <option value="1 - 2 times a week">1 - 2 times a week</option>
              </select>
            </div>
          {%- endif -%}
          {%- if section.settings.show_height_filter -%}
            <div class="reviews-filter">
              <label>{{ section.settings.height_filter_label }}</label>
              <select>
                <option value="">{{ section.settings.height_filter_placeholder }}</option>
                <option value="5ft4-5ft7 (163cm-172cm)">5ft4-5ft7 (163cm-172cm)</option>
                <option value="5ft8-5ft11 (173cm-182cm)">5ft8-5ft11 (173cm-182cm)</option>
                <option value="6ft-6ft3 (183cm-192)">6ft-6ft3 (183cm-192)</option>
                <option value="6ft4+(193cm)">6ft4+(193cm)</option>
              </select>
            </div>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    <div class="reviews-list">
      {%- for block in section.blocks -%}
        {%- if block.type == 'review' -%}
          {%- assign tags = block.settings.tags | split: ',' -%}
          {%- assign metrics = block.settings.metrics | split: '\n' -%}
          <article
            class="review-card"
            data-rating="{{ block.settings.rating }}"
            data-date-sort="{{ block.settings.date_sort }}"
            data-tags="{{ block.settings.tags | strip | downcase }}"
            data-metrics="{{ block.settings.metrics | strip | downcase }}"
            {{ block.shopify_attributes }}
          >
            <div class="review-card__header">
              <div class="review-card__author">
                <div class="review-card__name">{{ block.settings.name }}</div>
                {%- if block.settings.verified -%}
                  <div class="review-card__verified">
                    <span class="reviews-icon reviews-icon--check" aria-hidden="true">
                      <svg viewBox="0 0 24 24" role="presentation">
                        <path d="M9.2 16.2L5.6 12.6L4.2 14L9.2 19L20 8.2L18.6 6.8L9.2 16.2Z" fill="currentColor"></path>
                      </svg>
                    </span>
                    {{ section.settings.verified_text }}
                  </div>
                {%- endif -%}
                <div class="review-card__meta">
                  {%- for metric in metrics -%}
                    {%- assign parts = metric | split: ':' -%}
                    {%- assign label = parts | first | strip -%}
                    {%- assign value = parts | last | strip -%}
                    {%- if label != blank and value != blank -%}
                      <span><strong>{{ label }}:</strong> {{ value }}</span>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              </div>
              <div class="review-card__rating">
                <span class="review-card__rating-score">{{ block.settings.rating }}</span>
                <div class="reviews-summary__stars" aria-label="Average rating score {{ block.settings.rating }}" role="img">
                  {%- for i in (1..5) -%}
                    {%- assign star_value_review = block.settings.rating | minus: i | plus: 1 -%}
                    {%- if star_value_review < 0 -%}
                      {%- assign star_value_review = 0 -%}
                    {%- elsif star_value_review > 1 -%}
                      {%- assign star_value_review = 1 -%}
                    {%- endif -%}
                    {%- assign star_percent_review = star_value_review | times: 100 -%}
                    <span class="reviews-star">
                      <svg width="20" height="20" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <defs>
                          <clipPath id="review-star-{{ section.id }}-{{ block.id }}-{{ forloop.index }}">
                            <path d="M22.3498 27.54L14.0005 21.0646L5.60596 27.5165L8.8893 17.1675L0.460938 10.7745L10.8412 10.8569L14.0005 0.460938L17.1484 10.8569L27.5513 10.8216L19.1116 17.1675L22.3611 27.5518L22.3498 27.54Z" fill="{{ section.settings.star_fill }}"></path>
                          </clipPath>
                        </defs>
                        <rect x="0" y="0" width="{{ star_percent_review }}%" height="100%" fill="{{ section.settings.star_fill }}" clip-path="url(#review-star-{{ section.id }}-{{ block.id }}-{{ forloop.index }})"></rect>
                        <rect x="{{ star_percent_review }}%" y="0" width="100%" height="100%" fill="{{ section.settings.star_empty }}" clip-path="url(#review-star-{{ section.id }}-{{ block.id }}-{{ forloop.index }})"></rect>
                      </svg>
                    </span>
                  {%- endfor -%}
                </div>
              </div>
              <div class="review-card__date">{{ block.settings.date }}</div>
            </div>

            <h3 class="review-card__title">{{ block.settings.title }}</h3>
            <p class="review-card__body">{{ block.settings.body }}</p>

            {%- if tags.size > 0 -%}
              <div class="review-card__tags">
                {%- for tag in tags -%}
                  {%- assign tag_clean = tag | strip -%}
                  {%- if tag_clean != blank -%}
                    <span class="review-card__tag">{{ tag_clean }}</span>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            {%- endif -%}

            <div class="review-card__actions">
              <button type="button" class="review-card__action">
                <span class="reviews-icon reviews-icon--thumb" aria-hidden="true">
                  <svg viewBox="0 0 24 24" role="presentation">
                    <path d="M2 10h4v12H2V10zm18.5 1.3c0-1.2-.9-2.1-2.1-2.1h-6.2l.9-4.3.1-.5c0-.6-.2-1.1-.6-1.5L11 1 5.6 6.5C5.2 6.9 5 7.5 5 8.1V20c0 1.1.9 2 2 2h8.3c.8 0 1.6-.5 1.9-1.3l3-7.4c.1-.3.3-.7.3-1z" fill="currentColor"></path>
                  </svg>
                </span>
                {{ section.settings.helpful_yes_label }} {{ block.settings.helpful_yes }}
              </button>
              <button type="button" class="review-card__action">
                <span class="reviews-icon reviews-icon--thumb reviews-icon--down" aria-hidden="true">
                  <svg viewBox="0 0 24 24" role="presentation">
                    <path d="M22 14h-4V2h4v12zm-18.5-1.3c0 1.2.9 2.1 2.1 2.1h6.2l-.9 4.3-.1.5c0 .6.2 1.1.6 1.5L13 23l5.4-5.5c.4-.4.6-1 .6-1.6V4c0-1.1-.9-2-2-2H8.7c-.8 0-1.6.5-1.9 1.3l-3 7.4c-.1.3-.3.7-.3 1z" fill="currentColor"></path>
                  </svg>
                </span>
                {{ section.settings.helpful_no_label }} {{ block.settings.helpful_no }}
              </button>
            </div>

            {%- if block.settings.reply_title != blank and block.settings.reply_body != blank -%}
              <div class="review-card__reply">
                <strong>{{ block.settings.reply_title }}</strong> -- {{ block.settings.reply_body }}
              </div>
            {%- endif -%}
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.show_load_more -%}
      <button class="reviews-load-more" type="button">{{ section.settings.load_more_text }}</button>
    {%- endif -%}
  </div>
</section>

<script>
(function() {
  function initReviewMetrics(container) {
    if (!container) return;
    const tabs = container.querySelectorAll('[data-reviews-metrics] .reviews-average__tab');
    const bar = container.querySelector('.reviews-average__bar');
    const left = container.querySelector('[data-metric-left]');
    const center = container.querySelector('[data-metric-center]');
    const right = container.querySelector('[data-metric-right]');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        tabs.forEach((btn) => btn.classList.remove('is-active'));
        tab.classList.add('is-active');
        const percent = tab.dataset.percentage || 0;
        bar.style.setProperty('--percentage', `${percent}%`);
        if (left) left.textContent = tab.dataset.left || '';
        if (center) center.textContent = tab.dataset.center || '';
        if (right) right.textContent = tab.dataset.right || '';
      });
    });
  }

  function normalizeText(value) {
    return (value || '').toLowerCase().trim();
  }

  function parseMetricValue(metrics, key) {
    if (!metrics) return '';
    const lines = metrics.split('\\n');
    for (let i = 0; i < lines.length; i += 1) {
      const line = lines[i];
      if (!line) continue;
      const parts = line.split(':');
      if (parts.length < 2) continue;
      const label = normalizeText(parts[0]);
      const value = normalizeText(parts.slice(1).join(':'));
      if (label === key) return value;
    }
    return '';
  }

  function applyFilters(section) {
    const searchInput = section.querySelector('.reviews-search input');
    const searchValue = normalizeText(searchInput ? searchInput.value : '');
    const selects = section.querySelectorAll('.reviews-filter select');
    const sortSelect = selects[0];
    const ratingSelect = selects[1];
    const activitySelect = selects[2];
    const ageSelect = selects[3];
    const frequencySelect = selects[4];
    const heightSelect = selects[5];
    const ratingValue = ratingSelect ? ratingSelect.value : '';
    const activityValue = normalizeText(activitySelect ? activitySelect.value : '');
    const ageValue = normalizeText(ageSelect ? ageSelect.value : '');
    const frequencyValue = normalizeText(frequencySelect ? frequencySelect.value : '');
    const heightValue = normalizeText(heightSelect ? heightSelect.value : '');

    const list = section.querySelector('.reviews-list');
    const cards = Array.from(list.querySelectorAll('.review-card'));

    const filtered = cards.filter((card) => {
      const rating = card.dataset.rating || '';
      const tags = normalizeText(card.dataset.tags);
      const metrics = normalizeText(card.dataset.metrics);
      const contentText = normalizeText(card.innerText);

      if (ratingValue && rating !== ratingValue) return false;
      if (activityValue && !metrics.includes(activityValue)) return false;
      if (ageValue && !metrics.includes(ageValue)) return false;
      if (frequencyValue && !metrics.includes(frequencyValue)) return false;
      if (heightValue && !metrics.includes(heightValue)) return false;
      if (searchValue && !contentText.includes(searchValue) && !tags.includes(searchValue)) return false;
      return true;
    });

    cards.forEach((card) => {
      if (filtered.includes(card)) {
        if (card.dataset.hidden === 'true') {
          card.style.display = '';
          requestAnimationFrame(() => {
            card.classList.remove('is-hidden');
            card.dataset.hidden = 'false';
          });
        }
      } else {
        card.classList.add('is-hidden');
        card.dataset.hidden = 'true';
        setTimeout(() => {
          if (card.dataset.hidden === 'true') {
            card.style.display = 'none';
          }
        }, 200);
      }
    });

    const sorted = filtered.slice();
    const sortValue = sortSelect ? sortSelect.value : 'recent';
    sorted.sort((a, b) => {
      const ratingA = parseInt(a.dataset.rating || '0', 10);
      const ratingB = parseInt(b.dataset.rating || '0', 10);
      const dateA = parseInt(a.dataset.dateSort || '0', 10);
      const dateB = parseInt(b.dataset.dateSort || '0', 10);
      if (sortValue === 'highest') return ratingB - ratingA;
      if (sortValue === 'lowest') return ratingA - ratingB;
      if (sortValue === 'oldest') return dateA - dateB;
      return dateB - dateA;
    });

    sorted.forEach((card) => list.appendChild(card));
  }

  function initFilters(section) {
    if (!section) return;
    const filters = section.querySelectorAll('.reviews-filter select');
    const searchInput = section.querySelector('.reviews-search input');
    filters.forEach((select) => {
      select.addEventListener('change', () => applyFilters(section));
    });
    if (searchInput) {
      searchInput.addEventListener('input', () => applyFilters(section));
    }
  }

  document.querySelectorAll('.reviews-advanced').forEach((section) => {
    initReviewMetrics(section);
    initFilters(section);
  });
})();
</script>

{% schema %}
{
  "name": "Reviews advanced",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Reviews" },
    { "type": "range", "id": "rating_value", "label": "Average rating", "min": 0, "max": 5, "step": 0.1, "default": 4.6 },
    { "type": "text", "id": "total_text", "label": "Total text", "default": "Based on [count] reviews" },
    { "type": "range", "id": "total_reviews", "label": "Total reviews", "min": 0, "max": 500, "step": 5, "default": 20 },
    { "type": "range", "id": "recommend_percent", "label": "Recommend percent", "min": 0, "max": 100, "step": 1, "default": 92 },
    { "type": "text", "id": "snapshot_title", "label": "Snapshot title", "default": "Rating snapshot" },
    { "type": "text", "id": "average_title", "label": "Average title", "default": "Average ratings" },
    { "type": "text", "id": "verified_text", "label": "Verified label", "default": "Verified buyer" },
    { "type": "text", "id": "helpful_yes_label", "label": "Helpful yes label", "default": "Helpful" },
    { "type": "text", "id": "helpful_no_label", "label": "Helpful no label", "default": "Not helpful" },
    { "type": "header", "content": "Rating snapshot counts" },
