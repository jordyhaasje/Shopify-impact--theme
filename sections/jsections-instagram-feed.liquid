{%- comment -%}
  JSections - Instagram Feed Pro
  Version: 2.0.2
  Installed by: Hazify Sections

  ⚠️ Do not modify - updates will overwrite changes.
  To customize, duplicate this section in your theme.
  
  Features:
  - Instagram-style card design with profile avatar, username, location
  - Instagram action icons (heart, comment, share, bookmark)
  - Swiper carousel with scrollbar/navigation
  - Extensive customization options
  - Manual posts via blocks (no live API in storefront)
{%- endcomment -%}

{{ 'jsections-instagram-feed.css' | asset_url | stylesheet_tag }}
{{ 'jsections-instagram-feed-swiper-bundle.min.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign section_id = section.id
  assign show_profile_avatar = section.settings.show_profile_avatar
  assign show_username_top = section.settings.show_username_top
  assign show_location = section.settings.show_location
  assign show_action_icons = section.settings.show_action_icons
  assign show_dots_menu = section.settings.show_dots_menu
  assign show_username_bottom = section.settings.show_username_bottom
  assign show_date = section.settings.show_date
  assign show_nav_buttons = section.settings.show_nav_buttons
  assign show_scrollbar = section.settings.show_scrollbar
-%}

<style>
  .insta-section-{{ section_id }} {
    --insta-bg: {{ section.settings.section_background }};
    --insta-heading-color: {{ section.settings.heading_color }};
    --insta-heading-size: {{ section.settings.heading_size }}px;
    --insta-heading-size-mobile: {{ section.settings.heading_size | times: 0.65 }}px;
    --insta-heading-align: {{ section.settings.heading_alignment }};
    --insta-heading-margin: {{ section.settings.heading_margin_bottom }}px;
    --insta-container-width: {{ section.settings.container_width }}rem;
    --insta-padding-top: {{ section.settings.padding_top }}px;
    --insta-padding-bottom: {{ section.settings.padding_bottom }}px;
    --insta-padding-top-mobile: {{ section.settings.padding_top | times: 0.75 }}px;
    --insta-padding-bottom-mobile: {{ section.settings.padding_bottom | times: 0.75 }}px;
    --insta-padding-left: {{ section.settings.padding_horizontal }}rem;
    --insta-padding-right: {{ section.settings.padding_horizontal }}rem;
    
    /* Card Styling */
    --insta-card-bg: {{ section.settings.card_background }};
    --insta-card-border-color: {{ section.settings.card_border_color }};
    --insta-card-border-width: {{ section.settings.card_border_width }}px;
    --insta-card-radius: {{ section.settings.card_radius }}px;
    --insta-card-padding: {{ section.settings.card_padding }}px;
    --insta-card-gap: {{ section.settings.cards_gap }}px;
    --insta-image-radius: {{ section.settings.image_radius }}px;
    --insta-image-aspect: {{ section.settings.image_aspect_width }}/{{ section.settings.image_aspect_height }};
    
    /* Profile Avatar */
    --insta-avatar-size: {{ section.settings.avatar_size }}px;
    --insta-avatar-size-mobile: {{ section.settings.avatar_size | times: 0.75 }}px;
    
    /* Typography */
    --insta-username-color: {{ section.settings.username_color }};
    --insta-username-size: {{ section.settings.username_size }}px;
    --insta-username-size-mobile: {{ section.settings.username_size | times: 0.65 }}px;
    --insta-location-color: {{ section.settings.location_color }};
    --insta-location-size: {{ section.settings.location_size }}px;
    --insta-date-color: {{ section.settings.date_color }};
    --insta-date-size: {{ section.settings.date_size }}px;
    
    /* Icons */
    --insta-icon-color: {{ section.settings.icon_color }};
    --insta-icon-size: {{ section.settings.icon_size }}px;
    --insta-icon-gap: {{ section.settings.icon_gap }}px;
    
    /* Navigation */
    --insta-nav-bg: {{ section.settings.nav_button_bg }};
    --insta-nav-color: {{ section.settings.nav_button_color }};
    --insta-nav-hover-bg: {{ section.settings.nav_button_hover_bg }};
    --insta-nav-hover-color: {{ section.settings.nav_button_hover_color }};
    --insta-nav-size: {{ section.settings.nav_button_size }}px;
    --insta-scrollbar-bg: {{ section.settings.scrollbar_bg }};
    --insta-scrollbar-drag: {{ section.settings.scrollbar_drag }};
    
    /* Slider Settings */
    --insta-slides-desktop: {{ section.settings.slides_per_view_desktop }};
    --insta-slides-tablet: {{ section.settings.slides_per_view_tablet }};
    --insta-slides-mobile: {{ section.settings.slides_per_view_mobile }};
    --insta-gap-desktop: {{ section.settings.cards_gap }}px;
    --insta-gap-mobile: {{ section.settings.cards_gap_mobile }}px;
  }

  @media(min-width: 1024px) {
    .insta-section-{{ section_id }} {
      --insta-padding-left: {{ section.settings.padding_horizontal_desktop }}rem;
      --insta-padding-right: {{ section.settings.padding_horizontal_desktop }}rem;
    }
  }
</style>

<div 
  class="insta-section insta-section-{{ section_id }}"
  {{ section.shopify_attributes }}
>
  <div class="insta-section__container">
    {%- comment -%} Heading Section {%- endcomment -%}
    {% if section.settings.heading != blank %}
      <div class="insta-heading">
        <h2 class="insta-heading__text">
          {{ section.settings.heading }}
          {% if section.settings.instagram_username != blank and section.settings.show_username_in_heading %}
            <a href="https://www.instagram.com/{{ section.settings.instagram_username }}/" 
               target="_blank" 
               rel="noopener noreferrer"
               class="insta-heading__username">
              <strong>@{{ section.settings.instagram_username }}</strong>
            </a>
          {% endif %}
        </h2>
      </div>
    {% endif %}

    {%- comment -%} Instagram Feed Grid/Slider {%- endcomment -%}
    <div class="insta-items">
      <div class="insta-slider-wrapper">
        <div class="insta-slider swiper">
          <div class="swiper-wrapper">
            {%- comment -%} Static posts from blocks {%- endcomment -%}
            {% for block in section.blocks %}
              {% render 'jsections-instagram-feed-card', 
                block: block,
                section_settings: section.settings,
                section_id: section_id
              %}
            {% endfor %}
          </div>

          {%- if show_scrollbar -%}
            <div class="insta-scrollbar swiper-scrollbar"></div>
          {%- endif -%}
        </div>

        {%- if show_nav_buttons -%}
          <button class="insta-btn-prev" aria-label="Previous slide">
            <svg width="16" height="9" viewBox="0 0 16 9" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M16 1.38462L14.5455 0L8 6.23077L1.45455 0L0 1.38462L8 9L16 1.38462Z" fill="currentColor"/>
            </svg>
          </button>
          <button class="insta-btn-next" aria-label="Next slide">
            <svg width="16" height="9" viewBox="0 0 16 9" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M16 1.38462L14.5455 0L8 6.23077L1.45455 0L0 1.38462L8 9L16 1.38462Z" fill="currentColor"/>
            </svg>
          </button>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Follow Button CTA {%- endcomment -%}
    {% if section.settings.show_follow_button and section.settings.instagram_username != blank %}
      <div class="insta-cta">
        <a href="https://www.instagram.com/{{ section.settings.instagram_username }}/" 
           target="_blank" 
           rel="noopener noreferrer"
           class="insta-follow-btn"
           style="
             --btn-bg: {{ section.settings.button_bg }};
             --btn-color: {{ section.settings.button_color }};
             --btn-hover-bg: {{ section.settings.button_hover_bg }};
             --btn-hover-color: {{ section.settings.button_hover_color }};
           ">
          {%- if section.settings.show_button_icon -%}
            <svg class="insta-follow-btn__icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          {%- endif -%}
          {{ section.settings.button_text | replace: '[username]', section.settings.instagram_username }}
        </a>
      </div>
    {% endif %}
  </div>
</div>

{%- comment -%} Swiper JS (local asset) {%- endcomment -%}
{{ 'jsections-instagram-feed-swiper-bundle.min.js' | asset_url | script_tag }}

<script>
{% raw %}
(function() {
  function initInstaSlider() {
    const section = document.querySelector('.insta-section-{% endraw %}{{ section_id }}{% raw %}');
    if (!section) return;

    const sliderEl = section.querySelector('.insta-slider');
    if (!sliderEl) return;

    // Get CSS variables for responsive slides
    const style = getComputedStyle(section);
    const slidesDesktop = parseInt(style.getPropertyValue('--insta-slides-desktop')) || 4;
    const slidesTablet = parseInt(style.getPropertyValue('--insta-slides-tablet')) || 2;
    const slidesMobile = parseFloat(style.getPropertyValue('--insta-slides-mobile')) || 1.3;
    const gapDesktop = parseInt(style.getPropertyValue('--insta-gap-desktop')) || 20;
    const gapMobile = parseInt(style.getPropertyValue('--insta-gap-mobile')) || 16;

    const slider = new Swiper(sliderEl, {
      speed: 300,
      navigation: {
        nextEl: section.querySelector('.insta-btn-next'),
        prevEl: section.querySelector('.insta-btn-prev')
      },
      scrollbar: {
        el: section.querySelector('.insta-scrollbar'),
        draggable: true
      },
      breakpoints: {
        320: {
          spaceBetween: gapMobile,
          slidesPerView: slidesMobile
        },
        768: {
          spaceBetween: gapMobile,
          slidesPerView: slidesTablet
        },
        1024: {
          spaceBetween: gapDesktop,
          slidesPerView: slidesDesktop
        }
      }
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    initInstaSlider();
  });
  
  if (typeof Shopify !== 'undefined' && Shopify.designMode) {
    document.addEventListener('shopify:section:load', initInstaSlider);
    document.addEventListener('shopify:section:unload', initInstaSlider);
  }
})();
{% endraw %}
</script>

